{
  "layer": "top",
  "position": "top",
  "height": 34,

  "modules-left": ["custom/arch", "hyprland/workspaces"],
  "modules-center": ["clock"],
  "modules-right": [
    "pulseaudio",
    "network",
    "battery",
    "tray"
  ],

  "custom/arch": {
    "format": "",
    "tooltip": "Arch Linux",
    "on-click": "wofi --show drun"
  },

  "clock": {
    "format": "{:%I:%M %p}",
    "tooltip-format": "{:%A, %d %B %Y}"
  }
}
